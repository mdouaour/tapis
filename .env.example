# ============================================
# تاپيس | Tapis - Carpet Store Ecommerce
# Environment Configuration
# ============================================
# Copy this file to .env.local and fill in your values

# --- Supabase ---
# Get these from your Supabase project dashboard (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://tapis.dz
NEXT_PUBLIC_SITE_NAME=تاپيس

# --- WhatsApp ---
# Algerian phone number format: 213XXXXXXXXX (without +)
NEXT_PUBLIC_WHATSAPP_NUMBER=213550000000

# --- Admin ---
# Secret key for admin session signing (change this to a random string!)
ADMIN_SECRET=your-random-admin-secret-at-least-32-chars-long

# Default admin credentials (change immediately after first login)
# Email: admin@tapis.dz
# Password: admin123
